# ════════════════════════════════════════════════════════════════
#  AI Chat Demo — Environment Configuration
# ════════════════════════════════════════════════════════════════
#
#  Copy this file to `.env` and fill in YOUR OWN API keys.
#  This app does NOT ship with any keys — get your own (free) at:
#
#      https://aistudio.google.com/apikey
#
#  You can also configure these visually after starting the server:
#  open http://localhost:5000 → click the ⚙ Settings icon.
# ════════════════════════════════════════════════════════════════

# Required: at least one Google Gemini API key (starts with AIza...)
GEMINI_API_KEY=

# Optional: up to 4 additional keys for higher rate limits (round-robin rotation)
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

# Optional: override server port (dev mode only — run.sh hardcodes 5000)
# PORT=5000
